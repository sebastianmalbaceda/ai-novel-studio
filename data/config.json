  "mcp_servers": {
    "_comment": "Servidores MCP disponibles para extender capacidades del modelo. Cada servidor añade herramientas como búsqueda web, análisis de imágenes, etc. Se activan con enabled:true.",
    "minimax": {
      "type": "local",
      "command": [
        "uvx",
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "environment": {
        "MINIMAX_API_KEY": "${AI_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io"
      },
      "enabled": false,
      "description": "Herramientas de planificación y coding de Minimax"
    },
    "web_search": {
      "type": "local",
      "command": [
        "uvx",
        "tavily-mcp-server"
      ],
      "environment": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "enabled": false,
      "description": "Búsqueda web para investigación de tropos y referencias"
    },
    "brave_search": {
      "type": "local",
      "command": [
        "uvx",
        "brave-search-mcp"
      ],
      "environment": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "enabled": false,
      "description": "Búsqueda web alternativa via Brave Search"
    }
  },
